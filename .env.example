# GitHub Personal Access Token (read-only, repo-scoped)
# Used by Gitea to mirror your GitHub repos. The agent never sees this.
# Optional for public repos — required only for private repo mirroring.
# GITHUB_PAT=ghp_xxxx

# Directory for project workspaces on the host (default: ./container_volumes/).
# Each project gets a subdirectory here, bind-mounted as its Docker volume.
# Leave empty to use standard Docker volumes (data stays in /var/lib/docker).
# PROJECTS_DIR=./container_volumes/

# Host port for Gitea web UI (default: 3000)
# GITEA_PORT=3000

# How often Gitea pulls from GitHub (default: 1m). Use `sandbox sync` for on-demand.
# MIRROR_INTERVAL=1m

# DNS servers for agent containers (comma-separated, must be publicly routable). Defaults to Quad9.
SANDBOX_DNS=9.9.9.9,149.112.112.112

# ─── Repo Watch Safety Limits ────────────────────────────────────────────────
# Set inline when launching repo-watch, or export here for defaults.
# All optional — empty means unlimited.

# Max agentic iterations per invocation
# REPO_WATCH_MAX_TURNS=

# Cost ceiling per invocation (USD)
# REPO_WATCH_MAX_BUDGET_USD=

# Wall-clock limit per invocation (e.g. "10m", "1h")
# REPO_WATCH_TIMEOUT=

# ─── Reviewer Configuration ──────────────────────────────────────────────────
# Managed by 'fetch-sandbox.py setup'. You can also edit these manually.

# LLM provider for reviews: anthropic, openai, openrouter, local
# REVIEWER_PROVIDER=anthropic

# API key for the review LLM (not needed for local providers without auth)
# The agent never sees this key — it is only used by fetch-sandbox.py on the host.
# REVIEWER_API_KEY=sk-ant-xxxx

# Model to use. Examples:
#   anthropic:  claude-sonnet-4-5-20250929
#   openai:     gpt-4o
#   openrouter: anthropic/claude-sonnet-4-5-20250929
#   local:      meta-llama/Llama-3.1-70B-Instruct
# REVIEWER_MODEL=

# Custom API endpoint (required for local, optional for others)
# Default endpoints are built into fetch-sandbox.py. Override here if needed.
# REVIEWER_ENDPOINT=

# ─── CI Watch ────────────────────────────────────────────────────────────────
# Enable the CI watch background process (set by 'sandbox ci-watch setup')
# CI_WATCH_ENABLED=false

# How often to poll Gitea for new CI commands (seconds, default: 5)
# CI_WATCH_POLL_INTERVAL=5

# Generated by 'sandbox setup' — do not set manually
# GITEA_ADMIN_PASSWORD=
# GITEA_ADMIN_TOKEN=
# GITEA_SECRET_KEY=
