# GitHub Personal Access Token (read-only, repo-scoped)
# Used by Gitea to mirror your GitHub repos. The agent never sees this.
GITHUB_PAT=ghp_xxxx

# API key for Claude Code in agent containers.
# Only needed with --claude flag. If using VS Code Remote-SSH with the
# Claude Code extension, the extension manages its own key — skip this.
# Named SANDBOX_CLAUDE_KEY (not ANTHROPIC_API_KEY) to avoid accidentally
# picking up a key from the shell environment.
# SANDBOX_CLAUDE_KEY=sk-ant-xxxx

# Directory for project workspaces on the host (default: ./container_volumes/).
# Each project gets a subdirectory here, bind-mounted as its Docker volume.
# Leave empty to use standard Docker volumes (data stays in /var/lib/docker).
# PROJECTS_DIR=./container_volumes/

# Host port for Gitea web UI (default: 3000)
# GITEA_PORT=3000

# How often Gitea pulls from GitHub (default: 8h). Use `sandbox sync` for on-demand.
# MIRROR_INTERVAL=8h

# DNS servers for agent containers (comma-separated, must be publicly routable).
SANDBOX_DNS=9.9.9.9,149.112.112.112

# ─── Reviewer Configuration ──────────────────────────────────────────────────

# Enable or disable automated security review (default: true)
# Set to false to skip webhook creation and not start the review service.
REVIEWER_ENABLED=false

# LLM provider for reviews: anthropic, openai, openrouter, local
REVIEWER_PROVIDER=anthropic

# API key for the review LLM (not needed for local providers without auth)
# The agent cannot access this key — it runs in a separate container.
REVIEWER_API_KEY=sk-ant-xxxx

# Model to use (required). Examples:
#   anthropic:  claude-sonnet-4-5-20250929
#   openai:     gpt-4o
#   openrouter: anthropic/claude-sonnet-4-5-20250929
#   local:      meta-llama/Llama-3.1-70B-Instruct
REVIEWER_MODEL=claude-sonnet-4-5-20250929

# Custom API endpoint (required for local, optional for others)
# Default endpoints are in review/review-config.yaml.
# REVIEWER_ENDPOINT=

# Generated by 'sandbox setup' — do not set manually
# GITEA_ADMIN_TOKEN=
