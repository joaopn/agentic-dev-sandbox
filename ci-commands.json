{
  "_comment": "CI commands run by 'sandbox ci-watch' on the host. Test containers have no network and no tokens.",
  "defaults": {
    "timeout": 600,
    "memory": "2g",
    "cpus": "2",
    "rate_limit": 10,
    "rate_window": 3600
  },
  "commands": {
    "/test-pr-bug": {
      "description": "Verify a bug fix: test must FAIL on base branch, PASS on PR branch",
      "type": "bug-verification",
      "usage": "/test-pr-bug <test-file> <branch>",
      "args": {
        "test_file": {"pattern": "^[a-zA-Z0-9][a-zA-Z0-9/_.-]*\\.(py|sh)$"},
        "branch": {"pattern": "^[a-zA-Z0-9][a-zA-Z0-9/_.-]*$"}
      }
    },
    "/test-pr": {
      "description": "Run a test command on a branch in a clean container",
      "type": "command",
      "usage": "/test-pr \"<command>\" <branch>",
      "args": {
        "test_command": {"quoted": true},
        "branch": {"pattern": "^[a-zA-Z0-9][a-zA-Z0-9/_.-]*$"}
      }
    }
  }
}
