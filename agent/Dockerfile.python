FROM continuumio/miniconda3

ENV DEBIAN_FRONTEND=noninteractive

# Core tools: byobu, ssh, git, utilities
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl jq nano \
    byobu \
    openssh-server \
    iputils-ping \
    sudo \
    locales \
    && rm -rf /var/lib/apt/lists/*

# Locale setup (many tools expect UTF-8)
RUN sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen && locale-gen
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# SSH server setup
RUN mkdir -p /run/sshd && \
    sed -i 's/#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config && \
    sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    echo "AllowAgentForwarding no" >> /etc/ssh/sshd_config

# Create non-root user for the agent
RUN useradd -m -s /bin/bash -G sudo agent && \
    echo "agent ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/agent

# Initialize conda for the agent user (adds shell hooks to .bashrc)
RUN su - agent -c "/opt/conda/bin/conda init bash"

# Stash home directory (volume mount on /home/agent hides image contents)
RUN cp -a /home/agent /etc/agent-skel

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER agent
WORKDIR /home/agent

ENTRYPOINT ["/entrypoint.sh"]
